# Email (user-facing result delivery)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# KakaoTalk share SDK
VITE_KAKAO_APP_KEY=

# Payment provider: mock | toss | polar  (defaults to mock when unset)
VITE_PAYMENT_PROVIDER=mock

# Toss Payments — required when VITE_PAYMENT_PROVIDER=toss
# Dashboard: https://developers.tosspayments.com/
VITE_TOSS_CLIENT_KEY=

# Server-side Toss key (used by /api/confirm-payment Vercel Function).
# NEVER prefix with VITE_ — must stay off the client bundle.
# Set in Vercel dashboard → Settings → Environment Variables.
TOSS_SECRET_KEY=

# Polar — required when VITE_PAYMENT_PROVIDER=polar
# Dashboard: https://polar.sh/dashboard
VITE_POLAR_INDIVIDUAL_REPORT_URL=
VITE_POLAR_COUPLE_ADDON_URL=
VITE_POLAR_CONSULTATION_URL=
